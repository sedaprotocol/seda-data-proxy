{
	"name": "seda-data-proxy",
	"module": "./src/index.ts",
	"main": "./src/index.ts",
	"type": "module",
	"scripts": {
		"start": "bun run check-ts && bun run ./workspace/data-proxy",
		"fmt": "bunx biome check --write .",
		"build": "bun run check-ts && bun run build.ts",
		"check-fmt": "bunx biome check .",
		"check-ts": "bunx tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.5",
		"@types/bun": "^1.3.10",
		"@types/secp256k1": "^4.0.7",
		"@seda-protocol/utils": "2.0.0",
		"true-myth": "9.3.1"
	},
	"overrides": {
		"true-myth": "9.3.1"
	},
	"workspaces": [
		"workspace/*"
	],
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"patchedDependencies": {
		"@seda-protocol/utils@2.0.0": "patches/@seda-protocol%2Futils@2.0.0.patch"
	}
}
